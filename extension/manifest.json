{
  "name": "PhishSight AI",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Real-time phishing protection with automatic blocking.",
  "action": {
    "default_title": "PhishSight AI",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "<all_urls>"
  ]
}
